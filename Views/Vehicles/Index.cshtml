@model IEnumerable<VehicleRentalManagementSystem.Models.Vehicle>

@{
    ViewData["Title"] = "Vehicles";
}

<h1 class="mb-4 text-primary">Vehicles</h1>

<div class="mb-3 d-flex justify-content-between align-items-center">
    <a asp-action="Create" class="btn btn-success">
        Add New Vehicle
    </a>
    <input type="text" id="searchInput" class="form-control w-25" placeholder="Search by Make/Model">
</div>

<table class="table table-striped table-hover table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Make)</th>
            <th>@Html.DisplayNameFor(model => model.Model)</th>
            <th>@Html.DisplayNameFor(model => model.Year)</th>
            <th>@Html.DisplayNameFor(model => model.LicensePlate)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>@Html.DisplayNameFor(model => model.Mileage)</th>
            <th>@Html.DisplayNameFor(model => model.Category)</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Make</td>
                <td>@item.Model</td>
                <td>@item.Year</td>
                <td>@item.LicensePlate</td>
                <td style="color:@(item.Status == "Available" ? "green" : "red")">
                    @item.Status
                </td>
                <td>@item.Mileage</td>
                <td>@item.Category.CategoryName</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@item.VehicleId" class="btn btn-primary btn-sm me-1" style="width: 70px;">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.VehicleId" class="btn btn-info btn-sm text-white me-1" style="width: 70px;">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.VehicleId" class="btn btn-danger btn-sm" style="width: 70px;">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
      
        const searchInput = document.getElementById('searchInput');
        searchInput.addEventListener('keyup', function () {
            const filter = searchInput.value.toLowerCase();
            const rows = document.querySelectorAll('table tbody tr');
            rows.forEach(row => {
                const make = row.cells[0].textContent.toLowerCase();
                const model = row.cells[1].textContent.toLowerCase();
                row.style.display = (make.includes(filter) || model.includes(filter)) ? '' : 'none';
            });
        });
    </script>
}