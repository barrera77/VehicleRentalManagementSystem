@model VehicleRentalManagementSystem.Models.Vehicle

@{
    ViewData["Title"] = "Delete";
}

<h1 class="mb-3 text-danger">Delete</h1>

<h5 class="mb-4">Are you sure you want to delete this?</h5>

<div class="card mb-3 border-danger">
    <div class="card-body">

        <h4 class="mb-3">Vehicle</h4>
        <hr />

        <dl class="row mb-0">

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Make)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Make)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Model)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Model)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Year)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Year)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.LicensePlate)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.LicensePlate)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Status)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Status)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Mileage)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Mileage)
            </dd>

            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Category)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Category.CategoryName)
            </dd>

        </dl>

    </div>
</div>

<form asp-action="Delete" class="d-flex gap-2">
    <input type="hidden" asp-for="VehicleId" />

    <input type="submit" value="Delete"
           class="btn btn-danger"
           style="width: 100px;" />

    <a asp-action="Index"
           class="btn btn-secondary"
           style="width: 100px;">
        Back
    </a>
</form>