@model VehicleRentalManagementSystem.Models.Vehicle

@{
    ViewData["Title"] = "Vehicle Details";
}

<h1 class="mb-4 text-primary">Vehicle Details</h1>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.CategoryName</dd>

            <dt class="col-sm-3">Make</dt>
            <dd class="col-sm-9">@Model.Make</dd>

            <dt class="col-sm-3">Model</dt>
            <dd class="col-sm-9">@Model.Model</dd>

            <dt class="col-sm-3">Year</dt>
            <dd class="col-sm-9">@Model.Year</dd>

            <dt class="col-sm-3">License Plate</dt>
            <dd class="col-sm-9">@Model.LicensePlate</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Mileage</dt>
            <dd class="col-sm-9">@Model.Mileage</dd>

        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model?.VehicleId"
           class="btn btn-success" style="width: 100px;">
        Edit
    </a>

    <a asp-action="Index"
           class="btn btn-secondary" style="width: 100px;">
        Back
    </a>
</div>