@model VehicleRentalManagementSystem.Models.Reservation

@{
    ViewData["Title"] = "Cancel Reservation";
}

<h1 class="mb-4 text-primary">Cancel Reservation</h1>

<h3 class="mb-3 text-danger">Are you sure you want to cancel this reservation?</h3>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.StartDate)</dt>
            <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EndDate)</dt>
            <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-9" style="color:@(Model.Status == "Cancelled" ? "red" : "green")">
                @Model.Status
            </dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.CreatedAt)</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToShortDateString()</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Customer)</dt>
            <dd class="col-sm-9">@Model.Customer?.Email</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Vehicle)</dt>
            <dd class="col-sm-9">@Model.Vehicle?.LicensePlate</dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <form asp-action="Cancel" method="post">
        <input type="hidden" asp-for="ReservationId" />
        <input type="submit" value="Cancel Reservation" class="btn btn-danger" style="width: 150px;" />
    </form>
    <a asp-action="Index" class="btn btn-secondary" style="width: 100px;">Back</a>
</div>