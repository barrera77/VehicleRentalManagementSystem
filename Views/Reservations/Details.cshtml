@model VehicleRentalManagementSystem.Models.Reservation

@{
    ViewData["Title"] = "Reservation Details";
}

<h1 class="mb-4 text-primary">Reservation Details</h1>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Created At</dt>
            <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>

            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">@Model.Customer.Email</dd>

            <dt class="col-sm-3">Vehicle</dt>
            <dd class="col-sm-9">@Model.Vehicle.LicensePlate</dd>
        </dl>
    </div>
</div>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model?.ReservationId" class="btn btn-success" style="width: 120px;">
        Edit
    </a>
    <a asp-action="Index" class="btn btn-secondary" style="width: 120px;">
        Back
    </a>
</div>