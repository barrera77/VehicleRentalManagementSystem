@model VehicleRentalManagementSystem.Models.Reservation

@{
    ViewData["Title"] = "Reservation Details";

    var days = (Model.EndDate - Model.StartDate).Days + 1;
    var dailyRate = Model.Vehicle.Category.DailyRate;
    var additionalCharges = Model.Billing?.AdditionalCharges ?? 0;
    var baseAmount = dailyRate * days;
    var taxAmount = baseAmount * 0.13m;
    var totalAmount = baseAmount + taxAmount + additionalCharges;
}

<h1 class="mb-4 text-primary">Reservation Details</h1>

<!-- Reservation Info -->
<div class="card mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Start Date</dt>
            <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">End Date</dt>
            <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>

            <dt class="col-sm-3">Customer</dt>
            <dd class="col-sm-9">@Model.Customer.Email</dd>

            <dt class="col-sm-3">Vehicle</dt>
            <dd class="col-sm-9">@Model.Vehicle.LicensePlate (@dailyRate.ToString("C") per day × @days days)</dd>
        </dl>
    </div>
</div>

@if (Model.Billing != null)
{
    <!-- Billing Invoice -->
    <h3 class="text-primary mb-2">Invoice</h3>
    <div class="card mb-3">
        <div class="card-body">
            <table class="table table-bordered mb-3">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Daily Rate</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < days; i++)
                    {
                        var day = Model.StartDate.AddDays(i);
                        <tr>
                            <td>@day.ToString("yyyy-MM-dd")</td>
                            <td>@dailyRate.ToString("C")</td>
                            <td>@dailyRate.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>

            <dl class="row">
                <dt class="col-sm-4">Base Amount</dt>
                <dd class="col-sm-8">@baseAmount.ToString("C")</dd>

                <dt class="col-sm-4">Tax Amount (13%)</dt>
                <dd class="col-sm-8">@taxAmount.ToString("C")</dd>

                <dt class="col-sm-4">Additional Charges</dt>
                <dd class="col-sm-8">@additionalCharges.ToString("C")</dd>

                <dt class="col-sm-4">Total Amount</dt>
                <dd class="col-sm-8 fw-bold">@totalAmount.ToString("C")</dd>

                <dt class="col-sm-4">Payment Status</dt>
                <dd class="col-sm-8" style="color:@(
                                                         Model.Billing.PaymentStatus == "Paid" ? "green" :
                                                         Model.Billing.PaymentStatus == "Pending" ? "orange" : "red")">
                    @Model.Billing.PaymentStatus
                </dd>

                <dt class="col-sm-4">Billing Date</dt>
                <dd class="col-sm-8">@Model.Billing.BillingDate.ToString("yyyy-MM-dd")</dd>
            </dl>
        </div>
    </div>
}

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.ReservationId" class="btn btn-success" style="width: 120px;">Edit</a>
    <a asp-action="Index" class="btn btn-secondary" style="width: 120px;">Back</a>
</div>