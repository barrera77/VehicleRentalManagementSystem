@model IEnumerable<VehicleRentalManagementSystem.Models.Reservation>

@{
    ViewData["Title"] = "Reservations";
}

<h1 class="mb-4 text-primary">Reservations</h1>

<div class="mb-3 d-flex justify-content-between align-items-center">
    <a asp-action="Create" class="btn btn-success">
        Add New Reservation
    </a>
    <input type="text" id="searchInput" class="form-control w-25" placeholder="Search by Status/Customer">
</div>

<table class="table table-striped table-hover table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(model => model.StartDate)</th>
            <th>@Html.DisplayNameFor(model => model.EndDate)</th>
            <th>@Html.DisplayNameFor(model => model.Status)</th>
            <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
            <th>@Html.DisplayNameFor(model => model.Customer)</th>
            <th>@Html.DisplayNameFor(model => model.Vehicle)</th>
            <th class="text-center">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td style="color:@(item.Status == "Active" ? "green" : "red")">@item.Status</td>
                <td>@item.CreatedAt.ToShortDateString()</td>
                <td>@item.Customer?.Email</td>
                <td>@item.Vehicle?.LicensePlate</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@item.ReservationId" class="btn btn-primary btn-sm me-1" style="width: 70px;">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.ReservationId" class="btn btn-info btn-sm text-white me-1" style="width: 70px;">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.ReservationId" class="btn btn-danger btn-sm" style="width: 70px;">Cancel</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        const searchInput = document.getElementById('searchInput');
        searchInput.addEventListener('keyup', function () {
            const filter = searchInput.value.toLowerCase();
            const rows = document.querySelectorAll('table tbody tr');
            rows.forEach(row => {
                const status = row.cells[2].textContent.toLowerCase();
                const customer = row.cells[4].textContent.toLowerCase();
                row.style.display = (status.includes(filter) || customer.includes(filter)) ? '' : 'none';
            });
        });
    </script>
}